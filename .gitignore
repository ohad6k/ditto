# emulo never commits your mined data
emulo-out/
ditto-out/
you-corpus.txt
chunks/
*.you.md

# your actual profile — keep it local unless you WANT to share it
you.md
# ...and everything the skill and the lenses generate alongside it. The
# appendix holds your rawest verbatim quotes; it must never be committable
# by accident, least of all from inside a clone of this repo.
/you-appendix.md
/you-thinking.md
/you-designer.md
/you-writer.md
/you-video.md
!examples/
!examples/you.md

__pycache__/
*.pyc
.DS_Store
.venv/

# local working files, never part of the release
.superpowers/
.worktrees/
videos/
.tools/

# python packaging build artifacts
dist/
build/
*.egg-info/

# mcp registry publisher binary (downloaded, not committed)
mcp-publisher.exe

# local editor / dev tooling
.claude/
nul

# Emulo Proof private fixtures, profiles, reviewer records, and run artifacts
.emulo-proof-private/
proof-private/
emulo-proof-runs/

# local tool, not part of the project
mcp-publisher.exe

# render temp (puppeteer profiles, compiled comps)
.scratch/

# Cloudflare Worker local state and secrets
cloud/worker/node_modules/
cloud/worker/.wrangler/
cloud/worker/.dev.vars
cloud/worker/.dev.vars.*
!cloud/worker/.dev.vars.example
cloud/worker/worker-configuration.d.ts

# Internal working context never ships in the public repository.
# Agent plans, production evidence, and strategy notes live in the
# private repo; see archive/public-repo-internal there for history.
.viberaven/
docs/superpowers/
docs/release/
docs/FEEDBACK.md
