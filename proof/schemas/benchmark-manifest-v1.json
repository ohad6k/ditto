{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ohad6k/ditto/proof/schemas/benchmark-manifest-v1.json",
  "title": "Ditto Proof v1 benchmark manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "benchmark", "benchmark_version", "ditto_ref", "ditto_commit",
    "profile_manifest_sha256", "private_rubric_sha256", "public_rubric_sha256",
    "uncertainty_policy", "host_persistent_context", "systems", "pairs",
    "limitations", "created_at"
  ],
  "properties": {
    "schema": {"const": "ditto-proof/1"},
    "benchmark": {"const": "Ditto Proof v1"},
    "benchmark_version": {"const": "1.0.0"},
    "ditto_ref": {"const": "v0.3.7"},
    "ditto_commit": {"const": "5f4008b0c0df40dcadb92c8fd1ba4dcf3aee40d0"},
    "profile_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "private_rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "public_rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uncertainty_policy": {"const": "small-n, directional only; Wilson 95%; no significance claims"},
    "host_persistent_context": {"const": "absent"},
    "systems": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object"}},
    "pairs": {"type": "array", "minItems": 24, "maxItems": 24, "items": {"type": "object"}},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
